@page
@model CRMProject.Pages.Customers.IndexModel
@{
    ViewData["Title"] = "Customers";
}

<div class="container mt-5">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">Customers List</h2>

        <a asp-page="/Customers/Create" 
           class="btn btn-success shadow-sm">
            Add Customer
        </a>
    </div>

    <!-- Table Card -->
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body">

            <table class="table table-hover table-striped align-middle text-center">
                <thead class="table-dark">
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th width="180">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var customer in Model.ListCustomers)
                    {
                        <tr>
                            <td>@customer.Id</td>
                            <td class="fw-semibold">@customer.Name</td>
                            <td>@customer.Email</td>
                            <td>@customer.Phone</td>

                            <td>
                                <a href="/Customers/Edit?id=@customer.Id"
                                   class="btn btn-outline-primary btn-sm me-2">
                                     Edit
                                </a>

                                <a href="/Customers/Delete?id=@customer.Id"
                                   class="btn btn-outline-danger btn-sm">
                                     Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>