@page
@model CRMProject.Pages.Customers.EditModel
@{
    ViewData["Title"] = "Edit Customer";
}

<div class="container mt-5">

    <!-- Centered Card -->
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white rounded-top-4">
                    <h4 class="mb-0">Edit Customer</h4>
                </div>

                <div class="card-body p-4">

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger">
                            @Model.ErrorMessage
                        </div>
                    }

                    <form method="post">

                        <input type="hidden" asp-for="Id" />

                        <!-- Name -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Full Name</label>
                            <input asp-for="Name" class="form-control rounded-3" placeholder="Enter customer name" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <!-- Email -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email Address</label>
                            <input asp-for="Email" class="form-control rounded-3" placeholder="Enter email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <!-- Phone -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Phone Number</label>
                            <input asp-for="Phone" class="form-control rounded-3" placeholder="Enter phone number" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-between">
                            <a asp-page="/Customers/Index" 
                               class="btn btn-outline-secondary px-4">
                                Cancel
                            </a>

                            <button type="submit" 
                                    class="btn btn-success px-4 shadow-sm">
                                Update
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>

</div>